<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
    
    <servlet>
        <servlet-name>HelloWorldServlet</servlet-name>
        <servlet-class>hu.pte.mik.prog4.servlet.HelloWorldServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>PersonPaymentServlet</servlet-name>
        <servlet-class>hu.pte.mik.prog4.servlet.PersonPaymentServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>CompanyPaymentServlet</servlet-name>
        <servlet-class>hu.pte.mik.prog4.servlet.CompanyPaymentServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>ClientListServlet</servlet-name>
        <servlet-class>hu.pte.mik.prog4.servlet.ClientListServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>HelloWorldServlet</servlet-name>
        <url-pattern>/helloWorld</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>PersonPaymentServlet</servlet-name>
        <url-pattern>/personPayment</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>CompanyPaymentServlet</servlet-name>
        <url-pattern>/companyPayment</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ClientListServlet</servlet-name>
        <url-pattern>/clientList</url-pattern>
    </servlet-mapping>

    <filter>
        <filter-name>LoggerFilter</filter-name>
        <filter-class>hu.pte.mik.prog4.filter.LoggerFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>LoggerFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
</web-app>